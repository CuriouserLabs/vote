rules_version = '2';

// ===============================================================
// Data Model
// ===============================================================
//
// All operations require Firebase Authentication.
//
// Collection: rooms
// Document ID: 8-character alphanumeric room code
// Fields:
//   - hostId:         string (required, immutable) — Firebase UID of creator
//   - activeHostId:   string (required, mutable)   — who currently holds primary control
//   - status:         string (required) — 'active' or 'ended'
//   - participants:   map (required) — keyed by userId
//       { displayName: string(1–50), photoURL: string|null, isHost: bool, online: bool }
//   - participantIds: list of userId strings (required) — for querying user's sessions
//   - votes:          map (required) — keyed by userId, value is number or "?"
//   - revealed:       bool (required)
//   - round:          number int >= 1 (required)
//   - storyTitle:     string 0–200 chars (required)
//   - coHosts:        list of userId strings, max 50 (required)
//   - createdAt:      timestamp (required, immutable)
//
// Collection: retros
// Document ID: 8-character alphanumeric retro code
// Fields:
//   - hostId:                string (required, immutable)
//   - activeHostId:          string (required, mutable)
//   - status:                string (required) — 'active' or 'ended'
//   - participants:          map (required)
//   - participantIds:        list (required)
//   - coHosts:               list (required)
//   - columns:               list (required)
//   - cards:                 map (required)
//   - previousActionItems:   map (required)
//   - settings:              map (required) { anonymous, hideCards, revealed }
//   - timer:                 map (required) { duration, startedAt, running }
//   - createdAt:             timestamp (required, immutable)
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidRoomId(roomId) {
      return roomId.size() == 8;
    }

    function isValidDisplayName(name) {
      return name is string && name.size() >= 1 && name.size() <= 50;
    }

    function isValidUserId(uid) {
      return uid is string && uid.size() >= 1 && uid.size() <= 64;
    }

    function isValidVoteValue(v) {
      return (v is number && v >= 0 && v <= 9999) || v == '?';
    }

    function isValidParticipantsMap(p) {
      return p is map && p.size() <= 100;
    }

    function isValidVotesMap(v) {
      return v is map && v.size() <= 100;
    }

    function isValidCoHosts(c) {
      return c is list && c.size() <= 100;
    }

    function isValidParticipantIds(p) {
      return p is list && p.size() <= 100;
    }

    function isValidStatus(s) {
      return s is string && (s == 'active' || s == 'ended');
    }

    // ===============================================================
    // rooms/{roomId}
    // ===============================================================

    function isValidRoomCreate(data) {
      return data.keys().hasOnly(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'votes', 'revealed', 'round', 'storyTitle', 'coHosts', 'createdAt'])
          && data.keys().hasAll(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'votes', 'revealed', 'round', 'storyTitle', 'coHosts', 'createdAt'])
          && isValidUserId(data.hostId)
          && isValidUserId(data.activeHostId)
          && data.activeHostId == data.hostId
          && data.hostId == request.auth.uid
          && isValidStatus(data.status)
          && data.status == 'active'
          && isValidParticipantsMap(data.participants)
          && isValidParticipantIds(data.participantIds)
          && isValidVotesMap(data.votes)
          && data.revealed is bool
          && data.revealed == false
          && data.round is int
          && data.round == 1
          && data.storyTitle is string
          && data.storyTitle.size() <= 200
          && isValidCoHosts(data.coHosts)
          && data.createdAt is timestamp;
    }

    function isValidRoomUpdate(after, before) {
      return after.keys().hasOnly(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'votes', 'revealed', 'round', 'storyTitle', 'coHosts', 'createdAt'])
          && after.hostId == before.hostId
          && after.createdAt == before.createdAt
          && (!('activeHostId' in after) || isValidUserId(after.activeHostId))
          && isValidStatus(after.status)
          && isValidParticipantsMap(after.participants)
          && isValidParticipantIds(after.participantIds)
          && isValidVotesMap(after.votes)
          && after.revealed is bool
          && after.round is int
          && after.round >= 1
          && after.round <= 10000
          && after.storyTitle is string
          && after.storyTitle.size() <= 200
          && isValidCoHosts(after.coHosts);
    }

    match /rooms/{roomId} {
      allow get: if isAuthenticated()
                 && isValidRoomId(roomId);

      allow list: if isAuthenticated();

      allow create: if isAuthenticated()
                    && isValidRoomId(roomId)
                    && isValidRoomCreate(request.resource.data);

      allow update: if isAuthenticated()
                    && isValidRoomId(roomId)
                    && isValidRoomUpdate(request.resource.data, resource.data);
    }

    // ===============================================================
    // retros/{retroId}
    // ===============================================================

    function isValidRetroSettings(s) {
      return s is map
          && s.anonymous is bool
          && s.hideCards is bool
          && s.revealed is bool;
    }

    function isValidCardsMap(c) {
      return c is map && c.size() <= 500;
    }

    function isValidPreviousActionItemsMap(p) {
      return p is map && p.size() <= 500;
    }

    function isValidColumnsArray(c) {
      return c is list && c.size() <= 20;
    }

    function isValidTimer(t) {
      return t is map
          && t.duration is number
          && t.startedAt is number
          && t.running is bool;
    }

    function isValidRetroTitle(data) {
      return !('title' in data) || (data.title is string && data.title.size() <= 100);
    }

    function isValidRetroCreate(data) {
      return data.keys().hasOnly(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'coHosts', 'columns', 'cards', 'previousActionItems', 'settings', 'timer', 'createdAt', 'title'])
          && data.keys().hasAll(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'coHosts', 'columns', 'cards', 'previousActionItems', 'settings', 'timer', 'createdAt'])
          && isValidUserId(data.hostId)
          && isValidUserId(data.activeHostId)
          && data.activeHostId == data.hostId
          && data.hostId == request.auth.uid
          && isValidStatus(data.status)
          && data.status == 'active'
          && isValidParticipantsMap(data.participants)
          && isValidParticipantIds(data.participantIds)
          && isValidCoHosts(data.coHosts)
          && isValidColumnsArray(data.columns)
          && isValidCardsMap(data.cards)
          && isValidPreviousActionItemsMap(data.previousActionItems)
          && isValidRetroSettings(data.settings)
          && data.settings.revealed == false
          && isValidTimer(data.timer)
          && isValidRetroTitle(data)
          && data.createdAt is timestamp;
    }

    function isValidRetroUpdate(after, before) {
      return after.keys().hasOnly(['hostId', 'activeHostId', 'status', 'participants', 'participantIds', 'coHosts', 'columns', 'cards', 'previousActionItems', 'settings', 'timer', 'createdAt', 'title'])
          && after.hostId == before.hostId
          && after.createdAt == before.createdAt
          && (!('activeHostId' in after) || isValidUserId(after.activeHostId))
          && isValidStatus(after.status)
          && isValidParticipantsMap(after.participants)
          && isValidParticipantIds(after.participantIds)
          && isValidCoHosts(after.coHosts)
          && isValidColumnsArray(after.columns)
          && isValidCardsMap(after.cards)
          && isValidPreviousActionItemsMap(after.previousActionItems)
          && isValidRetroSettings(after.settings)
          && isValidTimer(after.timer)
          && isValidRetroTitle(after);
    }

    match /retros/{retroId} {
      allow get: if isAuthenticated()
                 && isValidRoomId(retroId);

      allow list: if isAuthenticated();

      allow create: if isAuthenticated()
                    && isValidRoomId(retroId)
                    && isValidRetroCreate(request.resource.data);

      allow update: if isAuthenticated()
                    && isValidRoomId(retroId)
                    && isValidRetroUpdate(request.resource.data, resource.data);
    }
  }
}
